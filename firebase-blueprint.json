{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores additional user information like age and name.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's display name." },
        "age": { "type": "integer", "description": "The user's age." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["name", "age", "email", "role", "createdAt"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "A personal journal entry written by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who wrote the entry." },
        "content": { "type": "string", "description": "The text content of the journal entry." },
        "mood": { "type": "string", "description": "The mood associated with the entry." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the entry was created." }
      },
      "required": ["userId", "content", "mood", "createdAt"]
    },
    "Mood": {
      "title": "Mood Entry",
      "description": "A daily mood check-in by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who logged the mood." },
        "mood": { "type": "string", "description": "The mood value (e.g., Happy, Sad, Neutral)." },
        "note": { "type": "string", "description": "An optional note about the mood." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the mood was logged." }
      },
      "required": ["userId", "mood", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/journals/{entryId}": {
      "schema": "JournalEntry",
      "description": "Collection of journal entries."
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Collection of mood check-ins."
    }
  }
}
